{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reyn.dev/openui/schemas/manifest.schema.json",
  "title": "OpenUI Layer 1 schema manifest",
  "description": "JSON Schema validating a Layer 1 OpenUI schema manifest. See docs/openui/spec/manifest.md for the prose specification.",
  "type": "object",
  "required": ["schema", "title", "description", "spec_version", "data", "actions", "channels", "components"],
  "additionalProperties": false,
  "properties": {
    "schema": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*\\/(v[0-9]+|[0-9]+\\.[0-9]+(\\.[0-9]+)?)$",
      "description": "Schema identifier in the form '<domain>/<version>'. Domain is lower-kebab; version is 'v<major>' (any compatible) or 'M.m' / 'M.m.p' (pinned)."
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "description": {
      "type": "string",
      "minLength": 1
    },
    "spec_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$",
      "description": "OpenUI Layer 0 version this manifest targets (e.g. '1.0')."
    },
    "data": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "minLength": 1,
          "description": "Type name referenced from sibling data.types.ts."
        },
        "description": { "type": "string" }
      }
    },
    "actions": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/action" },
      "propertyNames": { "$ref": "#/$defs/actionOrChannelName" }
    },
    "channels": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/channel" },
      "propertyNames": { "$ref": "#/$defs/actionOrChannelName" }
    },
    "components": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/component" },
      "propertyNames": { "$ref": "#/$defs/componentName" }
    },
    "extensions": {
      "type": "object",
      "description": "Free-form notes; never load-bearing."
    }
  },
  "$defs": {
    "action": {
      "type": "object",
      "required": ["description", "returns"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "payload": {
          "type": "object",
          "additionalProperties": { "type": "string" },
          "description": "Map of field name to TypeScript-style type expression. '?' suffix on the field name marks optional."
        },
        "returns": { "type": "string", "minLength": 1 }
      }
    },
    "channel": {
      "type": "object",
      "required": ["description", "event"],
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "event": { "type": "string", "minLength": 1 }
      }
    },
    "component": {
      "type": "object",
      "required": ["surface", "required", "props"],
      "additionalProperties": false,
      "properties": {
        "surface": { "enum": ["app", "studio", "shared"] },
        "required": { "type": "boolean" },
        "props": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "actionOrChannelName": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*(\\.[a-z][a-z0-9_]*)+$",
      "description": "Dot-separated lower-snake-case identifier with at least one dot."
    },
    "componentName": {
      "type": "string",
      "pattern": "^[A-Z][A-Za-z0-9]*$",
      "description": "PascalCase identifier."
    }
  }
}
