{
  "mcpServers": {
    "reyn_chunker": {
      "command": "python",
      "args": ["${REYN_PLUGIN_ROOT}/scripts/chunker_server.py"],
      "env": {
        "FASTMCP_SHOW_SERVER_BANNER": "false",
        "FASTMCP_CHECK_FOR_UPDATES": "off"
      }
    },
    "reyn_vector_store": {
      "command": "python",
      "args": ["${REYN_PLUGIN_ROOT}/scripts/vector_store_server.py"],
      "env": {
        "FASTMCP_SHOW_SERVER_BANNER": "false",
        "FASTMCP_CHECK_FOR_UPDATES": "off"
      }
    }
  }
}
